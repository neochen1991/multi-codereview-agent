    "light_max_parallel_experts": 1,
    "light_max_debate_rounds": 1
  },
  "network": {
    "verify_ssl": true,
    "use_system_trust_store": true,
    "ca_bundle_path": ""
  },
  "allowlist": {
    "tools": [
      "local_diff",
      "schema_diff"
    ],
    "skills": [
      "frontend-design"
    ],
    "mcp": [
      "github.diff",
      "playwright.snapshot"
